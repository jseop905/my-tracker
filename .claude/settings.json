{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "Skill(*)",
      "TaskCreate(*)",
      "TaskUpdate(*)",
      "TaskGet(*)",
      "TaskList(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "AskUserQuestion(*)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git blame *)"
    ],
    "ask": [
      "WebSearch(*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(npm install *)",
      "Bash(npm add *)",
      "Bash(pnpm install *)",
      "Bash(pnpm add *)",
      "Bash(yarn add *)",
      "Bash(git push *)",
      "Bash(git push --force-with-lease *)"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(rm -rf ~)*",
      "Bash(rm -rf .)",
      "Bash(rm -r .)*",
      "Bash(rm -r ./)*",
      "Bash(rm -rf *)*",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(curl*|*sh)*",
      "Bash(wget*|*sh)*",
      "Bash(*>~/.ssh/*)",
      "Bash(*>~/.bashrc)*",
      "Bash(*>~/.profile)*",
      "Bash(git push --force main)*",
      "Bash(git push --force origin main)*",
      "Bash(git push -f main)*",
      "Bash(git push -f origin main)*",
      "Bash(git push --force master)*",
      "Bash(git push --force origin master)*",
      "Bash(git push -f master)*",
      "Bash(git push -f origin master)*",
      "Bash(git reset --hard *)*",
      "Bash(git clean -f*)*",
      "Bash(git checkout -- .)*",
      "Bash(git restore .)*",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(npm publish)*",
      "Bash(eval *)*",
      "Bash(bash -c *)*",
      "Bash(sh -c *)*",
      "Read(./.git/**)",
      "Edit(./.git/**)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Write(./.env)",
      "Write(./.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/db-guard.sh\"",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/remote-command-guard.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/secret-filter.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/notify.sh\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
